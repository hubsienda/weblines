---
import Button from '@components/Button.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  buttonLabel?: string;
  external?: boolean;
}

const {
  title,
  description,
  href,
  buttonLabel = 'View route',
  external = href.startsWith('http')
} = Astro.props;
---

<article class="route-card card">
  <h3>{title}</h3>
  <p>{description}</p>
  <Button href={href} variant="ghost" external={external}>{buttonLabel} →</Button>
</article>

<style>
  .route-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.35rem;
  }

  .route-card h3 {
    margin: 0;
    color: var(--colour-dark);
    font-size: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .route-card p {
    margin: 0;
    color: var(--colour-muted);
  }
</style>
