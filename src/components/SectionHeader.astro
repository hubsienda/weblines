---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'centre';
}

const {
  eyebrow,
  title,
  description,
  align = 'left'
} = Astro.props;
---

<header class:list={['section-header', `section-header--${align}`]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</header>

<style>
  .section-header {
    max-width: 760px;
    margin-bottom: 1.8rem;
  }

  .section-header--centre {
    margin-inline: auto;
    text-align: center;
  }

  .section-header--centre .eyebrow {
    justify-content: center;
  }

  .section-header--centre .eyebrow::before {
    display: none;
  }

  .section-header h2 {
    margin: 0.35rem 0 0;
    color: var(--colour-dark);
    font-size: clamp(1.55rem, 3vw, 2.1rem);
    line-height: 1.16;
    letter-spacing: -0.035em;
  }

  .section-header p:not(.eyebrow) {
    margin: 0.9rem 0 0;
    color: var(--colour-muted);
    font-size: 1rem;
  }
</style>
