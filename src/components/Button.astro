---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  external?: boolean;
}

const {
  href,
  variant = 'primary',
  external = href.startsWith('http')
} = Astro.props;
---

<a
  class:list={['button', `button--${variant}`]}
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 42px;
    padding: 0.68rem 0.95rem;
    border-radius: var(--radius-button);
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1;
    text-decoration: none;
    letter-spacing: 0;
    transition:
      transform 140ms ease,
      border-color 140ms ease,
      background-color 140ms ease,
      color 140ms ease,
      box-shadow 140ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button--primary {
    border: 1px solid var(--colour-blue);
    background: var(--colour-blue);
    color: var(--colour-white);
    box-shadow: 0 8px 20px rgba(0, 153, 255, 0.14);
  }

  .button--primary:hover {
    color: var(--colour-white);
    background: #008fe8;
    border-color: #008fe8;
    box-shadow: 0 10px 24px rgba(0, 153, 255, 0.18);
  }

  .button--secondary {
    border: 1px solid var(--colour-line);
    background: var(--colour-white);
    color: var(--colour-dark);
    box-shadow: none;
  }

  .button--secondary:hover {
    border-color: rgba(0, 153, 255, 0.55);
    color: var(--colour-blue);
    background: var(--colour-white);
  }

  .button--ghost {
    min-height: auto;
    padding: 0;
    border: 0;
    border-radius: 0;
    color: var(--colour-blue);
    background: transparent;
    box-shadow: none;
  }

  .button--ghost:hover {
    transform: none;
    color: var(--colour-dark);
  }
</style>
