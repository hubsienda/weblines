---
import {
  JAMBASTIC_URL,
  QOOBIX_URL,
  SIENDA_LEGAL_URL,
  SIENDA_MEDIA_URL,
  SIENDA_URL
} from '../config/links';

const footerLinks = [
  { href: '/tools', label: 'Tools' },
  { href: '/field-notes', label: 'Field Notes' },
  { href: '/applied-systems', label: 'Applied Systems' },
  { href: '/idaas', label: 'IDAAS' },
  { href: '/request-review', label: 'Request Review' },
  { href: SIENDA_URL, label: 'Sienda Ltd' },
  { href: JAMBASTIC_URL, label: 'Jambastic' },
  { href: QOOBIX_URL, label: 'QOOBIX' },
  { href: SIENDA_MEDIA_URL, label: 'Sienda Media' },
  { href: SIENDA_LEGAL_URL, label: 'Legal' }
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="site-footer__brand">
      <img src="/logo.png" alt="Sienda Weblines" width="156" height="42" />
      <p>
        Practical diagnostics, field notes, applied systems, and review routes
        from Sienda for better business decisions.
      </p>
    </div>

    <nav class="site-footer__links" aria-label="Footer navigation">
      {
        footerLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="site-footer__bottom">
      <p>
        © {year}
        {' '}
        <a href={SIENDA_URL} target="_blank" rel="noopener noreferrer">Sienda Ltd</a>.
        {' '}
        All rights reserved | Company No. 08194971 • Registered in England & Wales
      </p>
      <p>Diagnosis before expensive decisions.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--colour-line);
    background: #333333;
    color: var(--colour-white);
  }

  .site-footer__inner {
    padding-block: 3rem 2rem;
  }

  .site-footer__brand {
    max-width: 660px;
  }

  .site-footer__brand img {
    display: block;
    max-height: 42px;
    width: auto;
    margin-bottom: 1.25rem;
    filter: brightness(0) invert(1);
  }

  .site-footer__brand p {
    margin: 0;
    color: rgba(255, 255, 255, 0.74);
  }

  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1rem;
    padding-block: 2.2rem;
  }

  .site-footer__links a,
  .site-footer__bottom a {
    color: rgba(255, 255, 255, 0.84);
    text-decoration: none;
    transition: color 140ms ease;
  }

  .site-footer__links a {
    font-size: 0.94rem;
    font-weight: 500;
  }

  .site-footer__links a:hover,
  .site-footer__bottom a:hover {
    color: var(--colour-blue);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.9rem;
  }

  .site-footer__bottom p {
    margin: 0;
  }

  @media (max-width: 840px) {
    .site-footer__bottom {
      display: grid;
    }
  }
</style>
