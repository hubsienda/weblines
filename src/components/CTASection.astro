---
import Button from '@components/Button.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';

interface Props {
  type: 'jambastic' | 'qoobix' | 'sienda-media' | 'review' | 'diagnostic';
}

const { type } = Astro.props;

const ctas = {
  jambastic: {
    title: 'Need secure temporary exchange?',
    text: 'Jambastic is designed for sensitive information that should be shared, used, and then stop being a permanent readable record.',
    label: 'Request a Jambastic Review',
    request: true
  },
  qoobix: {
    title: 'Need clearer market intelligence?',
    text: 'QOOBIX helps organisations analyse markets, detect opportunity, and produce structured intelligence for practical action.',
    label: 'Request a QOOBIX Review',
    request: true
  },
  'sienda-media': {
    title: 'Need practical guides or resources?',
    text: 'Sienda Media publishes paid guides, field tools, and downloadable material for clearer business decisions.',
    label: 'Request IDAAS Information',
    request: true
  },
  review: {
    title: 'Need a practical review?',
    text: 'If the problem involves risk, process, data, AI, automation, sensitive information, or market uncertainty, start with a focused review.',
    label: 'Request a Practical Review',
    request: true
  },
  diagnostic: {
    title: 'Start with a diagnostic.',
    text: 'Use a Sienda Weblines tool to test the problem before choosing the solution.',
    label: 'Diagnostic Tools',
    href: '/tools',
    request: false
  }
};

const cta = ctas[type];
---

<section class="cta-section">
  <div>
    <h2>{cta.title}</h2>
    <p>{cta.text}</p>
  </div>

  {
    cta.request ? (
      <ExternalFormButton label={cta.label} />
    ) : (
      <Button href={cta.href || '/tools'}>{cta.label}</Button>
    )
  }
</section>

<style>
  .cta-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding: clamp(1.5rem, 4vw, 2.25rem);
    border: 1px solid rgba(0, 153, 255, 0.24);
    border-radius: var(--radius-large);
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.12), transparent 22rem),
      var(--colour-white);
    box-shadow: var(--shadow-soft);
  }

  .cta-section h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.35rem, 2.4vw, 1.85rem);
    line-height: 1.15;
    letter-spacing: -0.035em;
  }

  .cta-section p {
    max-width: 660px;
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
  }

  @media (max-width: 720px) {
    .cta-section {
      display: grid;
    }
  }
</style>
