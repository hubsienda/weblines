---
import Button from '@components/Button.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import { SIENDA_MEDIA_URL } from '../config/links';

interface Props {
  type:
    | 'review'
    | 'secure-review'
    | 'market-review'
    | 'ai-review'
    | 'business-review'
    | 'jambastic'
    | 'qoobix'
    | 'idaas'
    | 'sienda-media'
    | 'diagnostic';
}

type CTAConfig =
  | {
      title: string;
      text: string;
      label: string;
      request: true;
    }
  | {
      title: string;
      text: string;
      label: string;
      request: false;
      href: string;
    };

const { type } = Astro.props;

const ctas: Record<Props['type'], CTAConfig> = {
  review: {
    title: 'Start with a practical review.',
    text: 'Use the review when the next step is commercially important and the wrong decision would cost time, money, trust, or operational clarity.',
    label: 'Request a Practical Review',
    request: true
  },
  'secure-review': {
    title: 'Need a Secure Information Review?',
    text: 'Use this when sensitive, temporary, client-related, access-related, or commercially important information is being exchanged through ordinary channels.',
    label: 'Request a Secure Information Review',
    request: true
  },
  'market-review': {
    title: 'Need a Market Intelligence Review?',
    text: 'Use this when the market question, competitor field, partner route, or candidate-organisation research needs to be clarified before choosing QOOBIX, IDAAS, or a smaller intelligence brief.',
    label: 'Request a Market Intelligence Review',
    request: true
  },
  'ai-review': {
    title: 'Need an AI & Automation Review?',
    text: 'Use this when the business is unsure whether the problem needs AI, ordinary automation, better data, clearer processes, a database, or human review.',
    label: 'Request an AI & Automation Review',
    request: true
  },
  'business-review': {
    title: 'Need a Business Engineering Review?',
    text: 'Use this when the problem involves operational mess, weak process, unclear responsibility, data confusion, or expensive technology uncertainty.',
    label: 'Request a Business Engineering Review',
    request: true
  },
  jambastic: {
    title: 'Need secure temporary exchange?',
    text: 'Jambastic may be the right route after the problem has been reviewed and the sensitive exchange risk is clear.',
    label: 'Request a Secure Information Review',
    request: true
  },
  qoobix: {
    title: 'Considering QOOBIX?',
    text: 'A Market Intelligence Review can clarify whether QOOBIX, IDAAS, or a smaller intelligence brief is the right route.',
    label: 'Request a Market Intelligence Review',
    request: true
  },
  idaas: {
    title: 'Need the intelligence, not the software?',
    text: 'Use IDAAS when you want Sienda to deliver structured business intelligence without asking your team to learn, manage, or operate another platform.',
    label: 'Request IDAAS Information',
    request: true
  },
  'sienda-media': {
    title: 'Need practical guides or resources?',
    text: 'Sienda Media publishes paid guides, field tools, templates, ebooks, and downloadable material for clearer business decisions.',
    label: 'Sienda Media',
    href: SIENDA_MEDIA_URL,
    request: false
  },
  diagnostic: {
    title: 'Start with a diagnostic.',
    text: 'Use a Sienda Weblines tool to test the problem before choosing the solution.',
    label: 'Diagnostic Tools',
    href: '/tools',
    request: false
  }
};

const cta = ctas[type];
---

<section class="cta-section">
  <div>
    <h2>{cta.title}</h2>
    <p>{cta.text}</p>
  </div>

  {
    cta.request ? (
      <ExternalFormButton label={cta.label} />
    ) : (
      <Button href={cta.href}>{cta.label}</Button>
    )
  }
</section>

<style>
  .cta-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding: clamp(1.5rem, 4vw, 2.25rem);
    border: 1px solid rgba(0, 153, 255, 0.24);
    border-radius: var(--radius-large);
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.12), transparent 22rem),
      var(--colour-white);
    box-shadow: var(--shadow-soft);
  }

  .cta-section h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.35rem, 2.4vw, 1.85rem);
    line-height: 1.15;
    letter-spacing: -0.035em;
  }

  .cta-section p {
    max-width: 660px;
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
  }

  @media (max-width: 720px) {
    .cta-section {
      display: grid;
    }
  }
</style>
