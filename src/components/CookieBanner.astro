<div class="cookie-banner" data-cookie-banner hidden>
  <div class="cookie-banner__content">
    <p>
      Sienda Weblines uses essential cookies and may process technical data to operate this site.
      Personal data is processed according to GDPR. Legal information is available from Sienda Ltd.
    </p>

    <div class="cookie-banner__actions">
      <a href="https://sienda.co.uk/legal/" rel="noopener noreferrer">Legal information</a>
      <button type="button" data-cookie-accept>Accept</button>
    </div>
  </div>
</div>

<script>
  const banner = document.querySelector('[data-cookie-banner]');
  const acceptButton = document.querySelector('[data-cookie-accept]');
  const storageKey = 'sienda-weblines-cookie-notice-accepted';

  if (banner && localStorage.getItem(storageKey) !== 'yes') {
    banner.removeAttribute('hidden');
  }

  acceptButton?.addEventListener('click', () => {
    localStorage.setItem(storageKey, 'yes');
    banner?.setAttribute('hidden', '');
  });
</script>

