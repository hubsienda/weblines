---
const serviceItems = [
  {
    href: '/secure-exchange',
    label: 'Secure Exchange',
    description: 'Sensitive temporary information and the Jambastic route.'
  },
  {
    href: '/market-intelligence',
    label: 'Market Intelligence',
    description: 'QOOBIX, IDAAS, analysis, opportunity, and verification.'
  },
  {
    href: '/idaas',
    label: 'IDAAS',
    description: 'Managed intelligence delivered as a service by Sienda.'
  },
  {
    href: '/ai-automation',
    label: 'AI & Automation',
    description: 'AI realism, automation, data, process, and review.'
  },
  {
    href: '/business-engineering',
    label: 'Business Engineering',
    description: 'Diagnosis before building and useful systems.'
  },
  {
    href: '/guides',
    label: 'Guides',
    description: 'Paid guides, templates, field tools, and downloadable resources.'
  }
];

const mobileItems = [
  { href: '/tools', label: 'Tools' },
  { href: '/field-notes', label: 'Field Notes' },
  { href: '/applied-systems', label: 'Applied Systems' },
  { href: '/secure-exchange', label: 'Secure Exchange' },
  { href: '/market-intelligence', label: 'Market Intelligence' },
  { href: '/idaas', label: 'IDAAS' },
  { href: '/ai-automation', label: 'AI & Automation' },
  { href: '/business-engineering', label: 'Business Engineering' },
  { href: '/guides', label: 'Guides' },
  { href: '/request-review', label: 'Request Review' }
];
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label="Sienda Weblines home">
      <img src="/logo.png" alt="Sienda Weblines" width="156" height="42" />
    </a>

    <nav class="site-header__nav" aria-label="Primary navigation">
      <a href="/tools">Tools</a>
      <a href="/field-notes">Field Notes</a>
      <a href="/applied-systems">Applied Systems</a>

      <div class="nav-dropdown">
        <button class="nav-dropdown__trigger" type="button" aria-expanded="false">
          Services
          <span class="nav-dropdown__chevron" aria-hidden="true"></span>
        </button>

        <div class="nav-dropdown__panel">
          <p class="nav-dropdown__label">Services</p>

          {
            serviceItems.map((item) => (
              <a class="nav-dropdown__item" href={item.href}>
                <strong>{item.label}</strong>
                <span>{item.description}</span>
              </a>
            ))
          }
        </div>
      </div>

      <a class="site-header__review" href="/request-review">Request Review</a>
    </nav>

    <details class="mobile-nav">
      <summary aria-label="Open navigation">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <nav class="mobile-nav__panel" aria-label="Mobile navigation">
        {
          mobileItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(220, 230, 239, 0.8);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1.15rem;
    min-height: 76px;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .site-header__brand img {
    display: block;
    max-height: 42px;
    width: auto;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-left: auto;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .site-header__nav a,
  .mobile-nav__panel a {
    text-decoration: none;
  }

  .site-header__nav > a {
    color: var(--colour-dark);
  }

  .site-header__nav > a:hover {
    color: var(--colour-blue);
  }

  .site-header__review {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.58rem 0.8rem;
    border: 1px solid var(--colour-blue);
    border-radius: var(--radius-button);
    background: var(--colour-blue);
    color: var(--colour-white) !important;
  }

  .site-header__review:hover {
    background: #0088e6;
    border-color: #0088e6;
    color: var(--colour-white) !important;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    min-height: 40px;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--colour-dark);
    font-weight: 700;
  }

  .nav-dropdown__trigger:hover,
  .nav-dropdown:focus-within .nav-dropdown__trigger,
  .nav-dropdown:hover .nav-dropdown__trigger {
    color: var(--colour-blue);
  }

  .nav-dropdown__chevron {
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-top: -0.16rem;
    border-right: 1.7px solid currentColor;
    border-bottom: 1.7px solid currentColor;
    transform: rotate(45deg);
    transition: transform 150ms ease;
  }

  .nav-dropdown:hover .nav-dropdown__chevron,
  .nav-dropdown:focus-within .nav-dropdown__chevron {
    margin-top: 0.16rem;
    transform: rotate(225deg);
  }

  .nav-dropdown__panel {
    position: absolute;
    top: calc(100% + 0.9rem);
    left: 50%;
    display: grid;
    gap: 0.25rem;
    width: 380px;
    padding: 0.85rem;
    border: 1px solid var(--colour-line);
    border-radius: var(--radius-medium);
    background: var(--colour-white);
    box-shadow: var(--shadow-soft);
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 6px);
    transition:
      opacity 150ms ease,
      visibility 150ms ease,
      transform 150ms ease;
  }

  .nav-dropdown:hover .nav-dropdown__panel,
  .nav-dropdown:focus-within .nav-dropdown__panel {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  .nav-dropdown__label {
    margin: 0 0 0.35rem;
    padding: 0.2rem 0.45rem;
    color: var(--colour-blue);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-dropdown__item {
    display: grid;
    gap: 0.18rem;
    padding: 0.75rem;
    border-radius: var(--radius-small);
    color: var(--colour-dark);
    text-decoration: none;
  }

  .nav-dropdown__item:hover {
    background: var(--colour-soft);
    color: var(--colour-dark);
  }

  .nav-dropdown__item strong {
    font-size: 0.94rem;
    line-height: 1.25;
  }

  .nav-dropdown__item span {
    color: var(--colour-muted);
    font-size: 0.85rem;
    line-height: 1.35;
    font-weight: 500;
  }

  .mobile-nav {
    display: none;
    margin-left: auto;
    position: relative;
  }

  .mobile-nav summary {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 0;
    border: 1px solid var(--colour-line);
    border-radius: var(--radius-button);
    list-style: none;
    background: var(--colour-white);
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary span {
    display: block;
    width: 18px;
    height: 2px;
    margin-inline: auto;
    background: var(--colour-dark);
    border-radius: 999px;
  }

  .mobile-nav__panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    display: grid;
    gap: 0.35rem;
    width: min(82vw, 320px);
    padding: 0.75rem;
    border: 1px solid var(--colour-line);
    border-radius: var(--radius-medium);
    background: var(--colour-white);
    box-shadow: var(--shadow-soft);
  }

  .mobile-nav__panel a {
    padding: 0.8rem 0.9rem;
    border-radius: var(--radius-small);
    color: var(--colour-dark);
    font-weight: 700;
  }

  .mobile-nav__panel a:hover {
    background: var(--colour-soft);
    color: var(--colour-blue);
  }

  @media (max-width: 1060px) {
    .site-header__nav {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }
</style>
