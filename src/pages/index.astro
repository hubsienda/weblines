---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ToolCard from '@components/ToolCard.astro';
import RouteCard from '@components/RouteCard.astro';
import ArticleCard from '@components/ArticleCard.astro';
import CTASection from '@components/CTASection.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import Button from '@components/Button.astro';
import { getCollection } from 'astro:content';
import { getFieldNoteSlug } from '../utils/fieldNotes';
import {
  GOOGLE_ENQUIRY_FORM_URL,
  TALLY_AI_THEATRE_DETECTOR_URL,
  TALLY_AUTOMATION_OR_AI_URL,
  TALLY_CONFIDENTIAL_COMMUNICATION_RISK_CHECKER_URL,
  TALLY_EMAIL_RISK_CHECKER_URL
} from '../config/links';

const notes = await getCollection('fieldNotes');
const featuredNotes = notes
  .filter((note) => note.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const reviewTracks = [
  {
    title: 'Secure Information Review',
    text: 'For sensitive short-lived information, exposed communication habits, access details, and confidential exchange risk.'
  },
  {
    title: 'Market Intelligence Review',
    text: 'For market uncertainty, competitor fields, partner routes, candidate organisations for verification, QOOBIX, or IDAAS.'
  },
  {
    title: 'AI & Automation Review',
    text: 'For unclear AI claims, automation decisions, data readiness, process confusion, and human-review controls.'
  },
  {
    title: 'Business Engineering Review',
    text: 'For operational friction, weak systems, software uncertainty, unclear responsibility, and practical next steps.'
  }
];
---

<Layout
  title="Sienda Weblines"
  description="Practical diagnostics, field notes, applied systems, and review routes from Sienda for better business decisions."
>
  <Hero
    eyebrow="Sienda Weblines"
    title="Diagnose the problem before choosing the solution."
    description="Before buying software, automating a process, trusting an AI proposal, exposing sensitive information, or entering a market, get the problem reviewed properly."
    primaryHref={GOOGLE_ENQUIRY_FORM_URL}
    primaryLabel="Request a Practical Review"
    secondaryHref="/tools"
    secondaryLabel="Diagnostic Tools"
  />

  <section class="page-section">
    <div class="container">
      <SectionHeader
        eyebrow="Diagnostics"
        title="Start with the problem, not the invoice."
        description="The tools help identify the real issue before choosing a system, supplier, consultant, platform, process, or specialist route."
      />

      <div class="grid grid--4">
        <ToolCard
          title="Should this be sent by email?"
          description="For sensitive information, access details, client data, private instructions, and anything that should not become a permanent readable record."
          bestFor="Quick communication-risk checks."
          route="Email Risk Checker, then Secure Information Review or Jambastic where appropriate."
          href={TALLY_EMAIL_RISK_CHECKER_URL}
          buttonLabel="Email Risk Checker"
        />

        <ToolCard
          title="Confidential Communication Risk Checker"
          description="For professional firms, advisers, consultants, agencies, and high-trust environments handling sensitive exchanges."
          bestFor="Sensitive temporary exchanges."
          route="Confidential checker, then Secure Information Review."
          href={TALLY_CONFIDENTIAL_COMMUNICATION_RISK_CHECKER_URL}
          buttonLabel="Risk Checker"
        />

        <ToolCard
          title="AI Theatre Detector"
          description="For proposals, platforms, consultants, internal projects, and “AI solutions” that may be more costume than substance."
          bestFor="AI claims before money is spent."
          route="Detector, then AI & Automation Review where appropriate."
          href={TALLY_AI_THEATRE_DETECTOR_URL}
          buttonLabel="AI Theatre Detector"
        />

        <ToolCard
          title="Automation or AI?"
          description="For businesses unsure whether they need AI, automation, better data, clearer processes, a database, a form, or human review."
          bestFor="Technology decisions before procurement."
          route="Diagnostic, then AI & Automation or Business Engineering Review."
          href={TALLY_AUTOMATION_OR_AI_URL}
          buttonLabel="Automation or AI?"
        />
      </div>
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <SectionHeader
        eyebrow="Paid starting point"
        title="The paid starting point: Sienda Practical Review"
        description="When the diagnostic result points to a serious issue, the next step is not another guess. Sienda Practical Review turns the problem into a structured recommendation: what should be protected, analysed, automated, simplified, reviewed, built, or avoided."
      />

      <div class="review-track-grid">
        {
          reviewTracks.map((track) => (
            <article class="review-track-card card">
              <h2>{track.title}</h2>
              <p>{track.text}</p>
            </article>
          ))
        }
      </div>

      <div class="review-actions">
        <ExternalFormButton label="Request a Practical Review" />
        <Button href="/request-review" variant="secondary">Explore the Review Tracks</Button>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <SectionHeader
        eyebrow="Routes"
        title="Where the review can lead"
        description="Jambastic, QOOBIX, IDAAS, Sienda Media, bespoke work, simplification, or no build at all may be the right answer. The review helps choose."
      />

      <div class="route-grid">
        <RouteCard
          title="Secure temporary exchange"
          description="For sensitive information that should be shared, used, and then stop being a permanent readable record."
          href="/secure-exchange"
          buttonLabel="Secure Exchange"
        />

        <RouteCard
          title="Market intelligence"
          description="For organisations that need analysis, candidate discovery for verification, and practical commercial direction."
          href="/market-intelligence"
          buttonLabel="Market Intelligence"
        />

        <RouteCard
          title="IDAAS"
          description="Need market intelligence without operating QOOBIX? IDAAS is Sienda’s managed intelligence service for organisations that want the results delivered directly."
          href="/idaas"
          buttonLabel="Explore IDAAS"
        />

        <RouteCard
          title="Applied systems"
          description="Anonymised examples of triage, guardrails, structured handoff, escalation, human review, and practical workflow design."
          href="/applied-systems"
          buttonLabel="Applied Systems"
        />

        <RouteCard
          title="Guides and field tools"
          description="For paid guides, diagnostic material, templates, ebooks, and practical downloadable resources."
          href="/guides"
          buttonLabel="Guides"
        />
      </div>
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <div class="applied-strip card">
        <div>
          <p class="eyebrow">Applied Systems</p>
          <h2>Applied systems, not AI theatre.</h2>
          <p>
            See anonymised examples of practical systems built around triage,
            guardrails, escalation, structured information, and human review.
          </p>
        </div>

        <div class="applied-strip__actions">
          <Button href="/applied-systems" variant="secondary">Applied Systems</Button>
          <ExternalFormButton label="Request a Practical Review" />
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <SectionHeader
        eyebrow="Field Notes"
        title="Clear thinking for expensive decisions."
        description="Practical notes on secure exchange, AI realism, automation, market intelligence, and business engineering."
      />

      {
        featuredNotes.length > 0 ? (
          <div class="grid grid--3">
            {
              featuredNotes.map((note) => (
                <ArticleCard
                  title={note.data.title}
                  description={note.data.description}
                  category={note.data.category}
                  date={note.data.date}
                  href={`/field-notes/${getFieldNoteSlug(note.id)}`}
                />
              ))
            }
          </div>
        ) : (
          <p class="empty-note">Field Notes will appear here once the first Markdown files are added.</p>
        )
      }
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <CTASection type="review" />
    </div>
  </section>
</Layout>

<style>
  .empty-note {
    max-width: 680px;
    margin: 0;
    color: var(--colour-muted);
  }

  .review-track-grid,
  .route-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .review-track-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .route-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .review-track-card {
    padding: 1.25rem;
  }

  .review-track-card h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.12rem, 2vw, 1.35rem);
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .review-track-card p {
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
    font-size: 0.96rem;
  }

  .review-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .applied-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.5rem, 4vw, 2.25rem);
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.11), transparent 24rem),
      var(--colour-white);
  }

  .applied-strip h2 {
    margin: 0.35rem 0 0;
    color: var(--colour-dark);
    font-size: clamp(1.55rem, 3vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: -0.035em;
  }

  .applied-strip p:not(.eyebrow) {
    max-width: 680px;
    margin: 0.8rem 0 0;
    color: var(--colour-muted);
  }

  .applied-strip__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    flex: 0 0 auto;
  }

  @media (max-width: 1080px) {
    .review-track-grid,
    .route-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .review-track-grid,
    .route-grid {
      grid-template-columns: 1fr;
    }

    .applied-strip {
      display: grid;
    }
  }
</style>
