---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ExternalLinkCard from '@components/ExternalLinkCard.astro';
import CTASection from '@components/CTASection.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import { SIENDA_MEDIA_URL } from '../config/links';
---

<Layout
  title="Guides"
  description="Sienda Media publishes paid guides, ebooks, diagnostic material, field tools, templates, and downloadable resources for clearer business decisions."
>
  <Hero
    eyebrow="Guides"
    title="Practical guides, not motivational confetti."
    description="Sienda Media contains paid guides, ebooks, diagnostic material, field tools, templates, and downloadable resources for clearer decisions about AI, automation, secure exchange, market intelligence, and business engineering."
    primaryHref={SIENDA_MEDIA_URL}
    primaryLabel="Sienda Media"
    secondaryHref="/request-review"
    secondaryLabel="Practical Review"
  />

  <section class="page-section">
    <div class="container">
      <SectionHeader
        title="Downloadable material for people who still have to make decisions"
        description="The guides are designed for business owners, managers, consultants, and professionals who need practical judgement before buying or building."
      />

      <div class="grid grid--3">
        <ExternalLinkCard
          title="Sienda Media"
          description="Paid guides, ebooks, diagnostic material, templates, field tools, and practical resources."
          href={SIENDA_MEDIA_URL}
          buttonLabel="Sienda Media"
        />

        <ExternalLinkCard
          title="The AI Theatre Detector"
          description="A practical guide for spotting expensive AI nonsense before it becomes a proposal, project, invoice, and quiet internal embarrassment."
          href={SIENDA_MEDIA_URL}
          buttonLabel="Guides"
        />

        <ExternalLinkCard
          title="Field tools"
          description="Practical material for clearer technology, process, communication, and market decisions."
          href={SIENDA_MEDIA_URL}
          buttonLabel="Resources"
        />
      </div>

      <div class="review-note card">
        <div>
          <h2>Need advice before buying a guide?</h2>
          <p>
            If the issue is operational, sensitive, technical, or commercially important,
            start with a Practical Review instead of guessing which resource applies.
          </p>
        </div>

        <ExternalFormButton label="Request a Practical Review" />
      </div>

      <CTASection type="sienda-media" />
    </div>
  </section>
</Layout>

<style>
  .review-note {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 2rem;
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .review-note h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .review-note p {
    max-width: 720px;
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
  }

  @media (max-width: 720px) {
    .review-note {
      display: grid;
    }
  }
</style>
