---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ExternalLinkCard from '@components/ExternalLinkCard.astro';
import CTASection from '@components/CTASection.astro';
---

<Layout
  title="Guides"
  description="Sienda Media publishes paid guides, ebooks, diagnostic material, field tools, templates, and downloadable resources for clearer business decisions."
>
  <Hero
    eyebrow="Guides"
    title="Practical guides, not motivational confetti."
    description="Sienda Media contains paid guides, ebooks, diagnostic material, field tools, templates, and downloadable resources for clearer decisions about AI, automation, secure exchange, market intelligence, and business engineering."
    primaryHref="https://siendamedia.com"
    primaryLabel="Visit Sienda Media"
    secondaryHref="/field-notes"
    secondaryLabel="Read Field Notes"
  />

  <section class="page-section">
    <div class="container">
      <SectionHeader
        title="Downloadable material for people who still have to make decisions"
        description="The guides are designed for business owners, managers, consultants, and professionals who need practical judgement before buying or building."
      />

      <div class="grid grid--3">
        <ExternalLinkCard
          title="Sienda Media"
          description="Paid guides, ebooks, diagnostic material, templates, field tools, and practical resources."
          href="https://siendamedia.com"
          buttonLabel="Visit store"
        />

        <ExternalLinkCard
          title="The AI Theatre Detector"
          description="A practical guide for spotting expensive AI nonsense before it becomes a proposal, project, invoice, and quiet internal embarrassment."
          href="https://siendamedia.com"
          buttonLabel="View guides"
        />

        <ExternalLinkCard
          title="Field tools"
          description="Practical material for clearer technology, process, communication, and market decisions."
          href="https://siendamedia.com"
          buttonLabel="View resources"
        />
      </div>

      <CTASection type="sienda-media" />
    </div>
  </section>
</Layout>
