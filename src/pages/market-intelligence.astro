---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import RouteCard from '@components/RouteCard.astro';
import CTASection from '@components/CTASection.astro';
import Button from '@components/Button.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import { QOOBIX_URL } from '../config/links';
---

<Layout
  title="Market Intelligence"
  description="Market intelligence from Sienda Weblines supports both QOOBIX and IDAAS: structured analysis, opportunity detection, and candidate organisations for verification."
>
  <Hero
    eyebrow="Market Intelligence"
    title="Market intelligence is not a list of names."
    description="A list can be useful. It is not strategy. It is not verification. It is not analysis. It is not a magical lead machine with a bow tie. Market intelligence must clarify where opportunity may exist and what deserves human verification."
    primaryHref={QOOBIX_URL}
    primaryLabel="Explore QOOBIX"
    secondaryHref="/idaas"
    secondaryLabel="Explore IDAAS"
  />

  <section class="page-section">
    <div class="container">
      <SectionHeader
        title="Two ways to use Sienda market intelligence"
        description="QOOBIX and IDAAS are related, but they are not the same thing."
      />

      <div class="two-route-grid">
        <article class="market-route card">
          <p>QOOBIX</p>
          <h2>For organisations that want a provisioned intelligence environment.</h2>
          <Button href={QOOBIX_URL} variant="secondary">Explore QOOBIX</Button>
        </article>

        <article class="market-route card">
          <p>IDAAS</p>
          <h2>For organisations that want Sienda to deliver the intelligence work as a service.</h2>
          <Button href="/idaas" variant="secondary">Explore IDAAS</Button>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <SectionHeader
        title="From noise to commercial direction"
        description="Market intelligence should produce practical outputs for action, not dashboard theatre."
      />

      <div class="grid grid--3">
        <RouteCard
          title="Strategic analysis"
          description="Clarify sectors, customer types, market signals, positioning, channels, opportunities, and weaknesses before spending commercial effort badly."
          href={QOOBIX_URL}
          buttonLabel="QOOBIX"
        />

        <RouteCard
          title="Managed intelligence service"
          description="Use IDAAS when you need the intelligence delivered directly, not another platform for your team to operate."
          href="/idaas"
          buttonLabel="IDAAS"
        />

        <RouteCard
          title="Discovery with verification"
          description="Candidate organisations must be treated as candidates for verification, not guaranteed leads, confirmed partners, or qualified prospects."
          href="/request-review"
          buttonLabel="Practical Review"
        />

        <RouteCard
          title="Practical exports"
          description="The value is not permanent dashboard admiration. The value is intelligence that can be downloaded, reviewed, edited, discussed, and used."
          href="/field-notes/market-intelligence"
          buttonLabel="Field Notes"
        />

        <RouteCard
          title="Commercial question first"
          description="The work begins with the market, country, sector, channel, competitor, distributor, partner, or opportunity question that needs answering."
          href="/request-review"
          buttonLabel="Request Review"
        />

        <RouteCard
          title="Human judgement"
          description="Market intelligence supports commercial judgement. It does not replace verification, review, negotiation, or professional responsibility."
          href="/business-engineering"
          buttonLabel="Business Engineering"
        />
      </div>

      <div class="request-strip card">
        <div>
          <h2>Need the result, not the platform?</h2>
          <p>
            IDAAS is the managed route when your organisation needs structured intelligence
            prepared and delivered by Sienda.
          </p>
        </div>

        <ExternalFormButton label="Request IDAAS Information" />
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <CTASection type="qoobix" />
    </div>
  </section>
</Layout>

<style>
  .two-route-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .market-route,
  .request-strip {
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .market-route {
    display: grid;
    align-content: space-between;
    gap: 1rem;
  }

  .market-route p {
    margin: 0;
    color: var(--colour-blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .market-route h2,
  .request-strip h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.3rem, 2.4vw, 1.75rem);
    line-height: 1.18;
    letter-spacing: -0.035em;
  }

  .request-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .request-strip p {
    max-width: 680px;
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
  }

  @media (max-width: 760px) {
    .two-route-grid,
    .request-strip {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
