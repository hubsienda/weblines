---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import RouteCard from '@components/RouteCard.astro';
import CTASection from '@components/CTASection.astro';
import Button from '@components/Button.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import {
  MARKET_ENTRY_REALITY_CHECK_URL,
  QOOBIX_URL
} from '../config/links';
---

<Layout
  title="Market Intelligence"
  description="Market intelligence from Sienda Weblines supports QOOBIX, IDAAS, Market Intelligence Review, and the Market Entry Reality Check."
>
  <Hero
    eyebrow="Market Intelligence"
    title="Market intelligence is not a list of names."
    description="A list can be useful. It is not strategy. It is not verification. It is not analysis. Market intelligence must clarify where opportunity may exist and what deserves human verification."
    primaryHref="/request-review"
    primaryLabel="Request a Market Intelligence Review"
    secondaryHref={MARKET_ENTRY_REALITY_CHECK_URL}
    secondaryLabel="Take the Reality Check"
  />

  <section class="page-section">
    <div class="container">
      <SectionHeader
        title="Three routes into market intelligence"
        description="QOOBIX, IDAAS, and Market Intelligence Review serve different needs. The review is the paid starting point when the route is not yet clear."
      />

      <div class="three-route-grid">
        <article class="market-route card">
          <p>QOOBIX</p>
          <h2>For organisations that want a provisioned intelligence environment.</h2>
          <Button href={QOOBIX_URL} variant="secondary">Explore QOOBIX</Button>
        </article>

        <article class="market-route card">
          <p>IDAAS</p>
          <h2>For organisations that want Sienda to deliver the intelligence work as a service.</h2>
          <Button href="/idaas" variant="secondary">Explore IDAAS</Button>
        </article>

        <article class="market-route card">
          <p>Market Intelligence Review</p>
          <h2>For organisations that need to clarify the market question before choosing the route.</h2>
          <ExternalFormButton label="Request a Market Intelligence Review" />
        </article>
      </div>

      <div class="reality-check-strip card">
        <div>
          <p class="eyebrow">Free Diagnostic</p>
          <h2>Not sure whether the market question is ready?</h2>
          <p>
            Use the Market Entry Reality Check before paying for research,
            outreach, distributors, databases, or trade activity.
          </p>
        </div>

        <Button href={MARKET_ENTRY_REALITY_CHECK_URL} variant="secondary">
          Take the Market Entry Reality Check
        </Button>
      </div>
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <SectionHeader
        title="From uncertainty to commercial direction"
        description="Market intelligence should produce practical outputs for action, not dashboard admiration."
      />

      <div class="grid grid--3">
        <RouteCard
          title="Strategic analysis"
          description="Clarify sectors, customer types, market signals, positioning, channels, opportunities, and weaknesses before spending commercial effort badly."
          href={QOOBIX_URL}
          buttonLabel="QOOBIX"
        />

        <RouteCard
          title="Managed intelligence service"
          description="Use IDAAS when you need the intelligence delivered directly, not another platform for your team to operate."
          href="/idaas"
          buttonLabel="IDAAS"
        />

        <RouteCard
          title="Discovery with verification"
          description="Candidate organisations must be treated as candidates for verification, not guaranteed leads, confirmed partners, or qualified prospects."
          href="/request-review"
          buttonLabel="Practical Review"
        />

        <RouteCard
          title="Practical exports"
          description="The value is intelligence that can be downloaded, reviewed, edited, discussed, and used."
          href="/field-notes/market-intelligence"
          buttonLabel="Field Notes"
        />

        <RouteCard
          title="Commercial question first"
          description="The work begins with the market, country, sector, channel, competitor, distributor, partner, or opportunity question that needs answering."
          href="/request-review"
          buttonLabel="Request Review"
        />

        <RouteCard
          title="Human judgement"
          description="Market intelligence supports commercial judgement. It does not replace verification, review, negotiation, or professional responsibility."
          href="/business-engineering"
          buttonLabel="Business Engineering"
        />
      </div>

      <div class="request-strip card">
        <div>
          <h2>Unsure which route fits?</h2>
          <p>
            Start with a Market Intelligence Review when the commercial question
            needs clarification before choosing QOOBIX, IDAAS, or a smaller intelligence brief.
          </p>
        </div>

        <ExternalFormButton label="Request a Market Intelligence Review" />
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <CTASection type="market-review" />
    </div>
  </section>
</Layout>

<style>
  .three-route-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .market-route,
  .request-strip,
  .reality-check-strip {
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .market-route {
    display: grid;
    align-content: space-between;
    gap: 1rem;
  }

  .market-route p {
    margin: 0;
    color: var(--colour-blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .market-route h2,
  .request-strip h2,
  .reality-check-strip h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    line-height: 1.18;
    letter-spacing: -0.035em;
  }

  .request-strip,
  .reality-check-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .reality-check-strip {
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.08), transparent 24rem),
      var(--colour-white);
  }

  .request-strip p,
  .reality-check-strip p:not(.eyebrow) {
    max-width: 680px;
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
  }

  @media (max-width: 900px) {
    .three-route-grid {
      grid-template-columns: 1fr;
    }

    .request-strip,
    .reality-check-strip {
      display: grid;
    }
  }
</style>
