---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
---

<Layout
  title="Legal"
  description="Legal information placeholder for Sienda Weblines."
  noindex={true}
>
  <Hero
    eyebrow="Legal"
    title="Legal information."
    description="This page is a placeholder for legal notices, policies, and related information for Sienda Weblines."
    primaryHref="https://sienda.co.uk"
    primaryLabel="Visit Sienda Ltd"
    secondaryHref="/"
    secondaryLabel="Return home"
  />

  <section class="page-section">
    <div class="reading-container prose">
      <h2>Placeholder</h2>
      <p>
        Legal content will be added here before production publication. Until then,
        this page should not be treated as legal advice, a privacy policy, terms of
        service, or a complete compliance notice.
      </p>
      <p>
        For company information, visit Sienda Ltd.
      </p>
    </div>
  </section>
</Layout>
