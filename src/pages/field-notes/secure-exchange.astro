---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import ArticleCard from '@components/ArticleCard.astro';
import CTASection from '@components/CTASection.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('fieldNotes');
const categoryNotes = notes
  .filter((note) => note.data.category === 'Secure Exchange')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Secure Exchange Field Notes"
  description="Field Notes on secure temporary exchange, confidential information, email risk, chat persistence, and Jambastic."
>
  <Hero
    eyebrow="Field Notes"
    title="Secure Exchange"
    description="Notes on sensitive information, temporary exchange, email risk, ordinary chat, professional exposure, and Jambastic."
    primaryHref="/secure-exchange"
    primaryLabel="View secure exchange route"
    secondaryHref="/tools"
    secondaryLabel="Use diagnostic tools"
  />

  <section class="page-section">
    <div class="container">
      {
        categoryNotes.length > 0 ? (
          <div class="grid grid--3">
            {
              categoryNotes.map((note) => (
                <ArticleCard
                  title={note.data.title}
                  description={note.data.description}
                  category={note.data.category}
                  date={note.data.date}
                  href={`/field-notes/${note.data.slug}`}
                />
              ))
            }
          </div>
        ) : (
          <p class="empty-note">No Secure Exchange Field Notes have been added yet.</p>
        )
      }

      <CTASection type="jambastic" />
    </div>
  </section>
</Layout>

<style>
  .empty-note {
    margin: 0;
    color: var(--colour-muted);
  }
</style>
