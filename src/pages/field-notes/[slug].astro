---
import Layout from '@layouts/Layout.astro';
import CategoryPill from '@components/CategoryPill.astro';
import ArticleCard from '@components/ArticleCard.astro';
import Button from '@components/Button.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import { getCollection } from 'astro:content';
import { getFieldNoteSlug } from '../../utils/fieldNotes';
import {
  JAMBASTIC_URL,
  QOOBIX_URL,
  SIENDA_MEDIA_URL,
  TALLY_AI_THEATRE_DETECTOR_URL,
  TALLY_AUTOMATION_OR_AI_URL,
  TALLY_CONFIDENTIAL_COMMUNICATION_RISK_CHECKER_URL,
  TALLY_EMAIL_RISK_CHECKER_URL
} from '../../config/links';

export async function getStaticPaths() {
  const notes = await getCollection('fieldNotes');

  return notes.map((note) => ({
    params: { slug: getFieldNoteSlug(note.id) },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

const allNotes = await getCollection('fieldNotes');
const relatedNotes = allNotes
  .filter((item) => item.id !== note.id && item.data.category === note.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric'
}).format(note.data.date);

const noteSlug = getFieldNoteSlug(note.id);
const category = String(note.data.category).toLowerCase();

const cta =
  category.includes('secure')
    ? {
        eyebrow: 'Secure Information Review',
        title: 'Does this risk exist in your own communication?',
        text: 'If the issue involves sensitive, temporary, client-related, access-related, or commercially important information, start with a Secure Information Review.',
        requestLabel: 'Request a Secure Information Review',
        links: [
          { href: JAMBASTIC_URL, label: 'Jambastic' },
          { href: TALLY_EMAIL_RISK_CHECKER_URL, label: 'Email Risk Checker' },
          { href: TALLY_CONFIDENTIAL_COMMUNICATION_RISK_CHECKER_URL, label: 'Risk Checker' }
        ]
      }
    : category.includes('ai') || category.includes('automation')
      ? {
          eyebrow: 'AI & Automation Review',
          title: 'Before the proposal becomes an invoice.',
          text: 'If the issue involves AI claims, automation decisions, data readiness, process confusion, or human-review controls, request an AI & Automation Review.',
          requestLabel: 'Request an AI & Automation Review',
          links: [
            { href: TALLY_AI_THEATRE_DETECTOR_URL, label: 'AI Theatre Detector' },
            { href: TALLY_AUTOMATION_OR_AI_URL, label: 'Automation or AI?' },
            { href: SIENDA_MEDIA_URL, label: 'Sienda Media' }
          ]
        }
      : category.includes('market')
        ? {
            eyebrow: 'Market Intelligence Review',
            title: 'Clarify the market question before choosing the route.',
            text: 'If the issue involves market uncertainty, competitor mapping, partner routes, or candidate organisations for verification, start with a Market Intelligence Review.',
            requestLabel: 'Request a Market Intelligence Review',
            links: [
              { href: '/idaas', label: 'IDAAS' },
              { href: QOOBIX_URL, label: 'QOOBIX' }
            ]
          }
        : category.includes('business')
          ? {
              eyebrow: 'Business Engineering Review',
              title: 'Turn the operational problem into a practical route.',
              text: 'If the issue involves weak processes, unclear responsibility, data confusion, software uncertainty, or expensive technology decisions, request a Business Engineering Review.',
              requestLabel: 'Request a Business Engineering Review',
              links: [
                { href: '/tools', label: 'Diagnostic Tools' },
                { href: '/applied-systems', label: 'Applied Systems' }
              ]
            }
          : {
              eyebrow: 'Practical Review',
              title: 'Start with a practical review.',
              text: 'If the next step is commercially important, the review helps clarify what should be protected, analysed, automated, simplified, reviewed, built, or avoided.',
              requestLabel: 'Request a Practical Review',
              links: [
                { href: '/tools', label: 'Diagnostic Tools' },
                { href: '/applied-systems', label: 'Applied Systems' }
              ]
            };
---

<Layout
  title={note.data.title}
  description={note.data.description}
  canonical={`/field-notes/${noteSlug}`}
>
  <article class="article-page">
    <header class="article-hero">
      <div class="reading-container">
        <div class="article-hero__meta">
          <CategoryPill label={note.data.category} />
          <time datetime={note.data.date.toISOString()}>{formattedDate}</time>
        </div>

        <h1>{note.data.title}</h1>
        <p>{note.data.description}</p>
      </div>
    </header>

    <div class="reading-container prose article-content">
      <Content />

      <section class="field-note-cta">
        <p class="eyebrow">{cta.eyebrow}</p>
        <h2>{cta.title}</h2>
        <p>{cta.text}</p>

        <div class="field-note-cta__actions">
          <ExternalFormButton label={cta.requestLabel} />
          {
            cta.links.map((link) => (
              <Button href={link.href} variant="secondary">
                {link.label}
              </Button>
            ))
          }
        </div>
      </section>
    </div>
  </article>

  {
    relatedNotes.length > 0 && (
      <section class="page-section page-section--soft">
        <div class="container">
          <h2 class="related-title">Related Field Notes</h2>

          <div class="grid grid--3">
            {
              relatedNotes.map((item) => (
                <ArticleCard
                  title={item.data.title}
                  description={item.data.description}
                  category={item.data.category}
                  date={item.data.date}
                  href={`/field-notes/${getFieldNoteSlug(item.id)}`}
                />
              ))
            }
          </div>
        </div>
      </section>
    )
  }
</Layout>

<style>
  .article-hero {
    padding-block: clamp(3.5rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--colour-line);
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.08), transparent 32rem),
      var(--colour-white);
  }

  .article-hero__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .article-hero time {
    color: var(--colour-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .article-hero h1 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.9rem, 4.4vw, 3.15rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  .article-hero p {
    margin: 1rem 0 0;
    color: var(--colour-muted);
    font-size: clamp(1rem, 1.7vw, 1.14rem);
    line-height: 1.55;
  }

  .article-content {
    padding-block: 3.5rem;
  }

  .field-note-cta {
    margin-top: 3rem;
    padding: clamp(1.5rem, 4vw, 2.25rem);
    border: 1px solid rgba(0, 153, 255, 0.24);
    border-radius: var(--radius-large);
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.12), transparent 22rem),
      var(--colour-white);
    box-shadow: var(--shadow-soft);
  }

  .field-note-cta h2 {
    margin: 0.35rem 0 0;
    color: var(--colour-dark);
    font-size: clamp(1.35rem, 2.4vw, 1.85rem);
    line-height: 1.15;
    letter-spacing: -0.035em;
  }

  .field-note-cta p:not(.eyebrow) {
    margin: 0.75rem 0 0;
    color: var(--colour-muted);
  }

  .field-note-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .related-title {
    margin: 0 0 1.4rem;
    color: var(--colour-dark);
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.16;
    letter-spacing: -0.035em;
  }
</style>
