---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import ArticleCard from '@components/ArticleCard.astro';
import CTASection from '@components/CTASection.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('fieldNotes');
const categoryNotes = notes
  .filter((note) => note.data.category === 'Business Engineering')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Business Engineering Field Notes"
  description="Field Notes on diagnosis before building, operational clarity, smart capital, useful systems, and commercial judgement."
>
  <Hero
    eyebrow="Field Notes"
    title="Business Engineering"
    description="Notes on diagnosis before building, operational clarity, useful systems, smart capital, and commercial judgement."
    primaryHref="/business-engineering"
    primaryLabel="View business engineering route"
    secondaryHref="/request-review"
    secondaryLabel="Request review"
  />

  <section class="page-section">
    <div class="container">
      {
        categoryNotes.length > 0 ? (
          <div class="grid grid--3">
            {
              categoryNotes.map((note) => (
                <ArticleCard
                  title={note.data.title}
                  description={note.data.description}
                  category={note.data.category}
                  date={note.data.date}
                  href={`/field-notes/${note.data.slug}`}
                />
              ))
            }
          </div>
        ) : (
          <p class="empty-note">No Business Engineering Field Notes have been added yet.</p>
        )
      }

      <CTASection type="review" />
    </div>
  </section>
</Layout>

<style>
  .empty-note {
    margin: 0;
    color: var(--colour-muted);
  }
</style>
