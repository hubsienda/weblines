---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import ArticleCard from '@components/ArticleCard.astro';
import CTASection from '@components/CTASection.astro';
import { getCollection } from 'astro:content';
import { getFieldNoteSlug } from '../../utils/fieldNotes';

const notes = await getCollection('fieldNotes');
const categoryNotes = notes
  .filter((note) => note.data.category === 'AI & Automation')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="AI & Automation Field Notes"
  description="Field Notes on AI realism, automation, process, data, human judgement, and technology theatre."
>
  <Hero
    eyebrow="Field Notes"
    title="AI & Automation"
    description="Notes on AI realism, automation discipline, process clarity, data quality, human judgement, and technology theatre."
    primaryHref="/ai-automation"
    primaryLabel="AI & Automation"
    secondaryHref="/tools"
    secondaryLabel="Diagnostic Tools"
  />

  <section class="page-section">
    <div class="container">
      {
        categoryNotes.length > 0 ? (
          <div class="grid grid--3">
            {
              categoryNotes.map((note) => (
                <ArticleCard
                  title={note.data.title}
                  description={note.data.description}
                  category={note.data.category}
                  date={note.data.date}
                  href={`/field-notes/${getFieldNoteSlug(note.id)}`}
                />
              ))
            }
          </div>
        ) : (
          <p class="empty-note">No AI & Automation Field Notes have been added yet.</p>
        )
      }

      <CTASection type="diagnostic" />
    </div>
  </section>
</Layout>

<style>
  .empty-note {
    margin: 0;
    color: var(--colour-muted);
  }
</style>
