---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import ExternalFormButton from '@components/ExternalFormButton.astro';
import CTASection from '@components/CTASection.astro';
import { GOOGLE_ENQUIRY_FORM_URL } from '../config/links';

const tracks = [
  {
    title: 'Secure Information Review',
    text: 'For companies handling sensitive short-lived information: passwords, access instructions, client details, private links, settlement figures, confidential notes, professional instructions, or commercially sensitive material.',
    route: 'Route after review may include Jambastic, secure exchange procedure, communication-risk reduction, and internal handling rules.',
    label: 'Request a Secure Information Review'
  },
  {
    title: 'Market Intelligence Review',
    text: 'For companies that need to understand a market, competitor field, partner or distributor landscape, market-entry opportunity, or candidate organisations for verification.',
    route: 'Route after review may include QOOBIX, IDAAS, market intelligence brief, competitor mapping, and candidate organisations for verification.',
    label: 'Request a Market Intelligence Review'
  },
  {
    title: 'AI & Automation Review',
    text: 'For companies unsure whether a problem needs AI, ordinary automation, better data, clearer processes, a database, a form, or human judgement.',
    route: 'Route after review may include AI Theatre Detector, Automation or AI?, workflow redesign, automation plan, human-review controls, and data-readiness work.',
    label: 'Request an AI & Automation Review'
  },
  {
    title: 'Business Engineering Review',
    text: 'For operationally messy problems involving systems, process friction, data confusion, unclear responsibilities, software decisions, or expensive technology uncertainty.',
    route: 'Route after review may include business process diagnosis, software specification, bespoke system plan, operational redesign, and implementation roadmap.',
    label: 'Request a Business Engineering Review'
  }
];

const deliverables = [
  'Problem diagnosis',
  'Risk and friction map',
  'Recommended route',
  'Technology, process, and data assessment',
  'Next-step action plan',
  'Where Jambastic, QOOBIX, IDAAS, guides, automation, or bespoke work may fit',
  'Where doing nothing or simplifying may be better'
];

const usefulWhen = [
  'The business is unsure whether it needs AI or automation.',
  'Sensitive information is being exchanged through ordinary channels.',
  'Market opportunity is unclear.',
  'A company is considering QOOBIX or IDAAS.',
  'A software idea may be premature.',
  'A process is broken but the solution is not obvious.',
  'An AI proposal sounds impressive but vague.',
  'Management needs a practical decision before spending money.'
];
---

<Layout
  title="Sienda Practical Review"
  description="A paid business engineering review for companies facing sensitive information risks, AI and automation confusion, market uncertainty, weak processes, or expensive technology decisions."
>
  <Hero
    eyebrow="Sienda Practical Review"
    title="Before choosing the solution, diagnose the problem."
    description="Sienda Practical Review is a paid business engineering review for companies facing sensitive information risks, AI and automation decisions, market uncertainty, weak processes, unclear data, or expensive technology choices."
    primaryHref={GOOGLE_ENQUIRY_FORM_URL}
    primaryLabel="Request a Practical Review"
    secondaryHref="/tools"
    secondaryLabel="Use a Diagnostic Tool"
  />

  <section class="page-section">
    <div class="container">
      <SectionHeader
        title="What the review is"
        description="A Practical Review is not a sales call, a vague consultation, or a software demo. It is a structured review of the business problem, the operational context, the risks, the possible routes, and the next practical action."
      />

      <div class="review-definition card">
        <p>
          The review helps clarify whether the business needs secure exchange, AI,
          automation, better data, market intelligence, workflow redesign, human review,
          a guide, a software system, or nothing at all.
        </p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <SectionHeader
        title="Review tracks"
        description="The review route depends on the problem. Each track is practical, bounded, and designed to clarify the next commercial action."
      />

      <div class="track-grid">
        {
          tracks.map((track) => (
            <article class="track-card card">
              <h2>{track.title}</h2>
              <p>{track.text}</p>
              <p class="track-card__route">{track.route}</p>
              <ExternalFormButton label={track.label} />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <SectionHeader
        title="What you receive"
        description="The exact output depends on the problem, but the purpose is always the same: make the next decision clearer."
      />

      <div class="deliverable-grid">
        {
          deliverables.map((item) => (
            <article class="deliverable-card card">
              <h2>{item}</h2>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="page-section page-section--soft">
    <div class="container">
      <SectionHeader
        title="When this is useful"
        description="The review is useful when the next step matters and guessing would be expensive."
      />

      <div class="useful-grid">
        {
          usefulWhen.map((item) => (
            <article class="useful-card card">
              <p>{item}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <div class="anti-hype card">
        <div>
          <p class="eyebrow">Not for everyone</p>
          <h2>Not every problem deserves a new system.</h2>
          <p>
            Sometimes the right answer is software. Sometimes it is AI. Sometimes it is automation.
            Sometimes it is better data, a clearer process, safer exchange, market intelligence,
            or human review. Sometimes the best answer is to stop building the wrong thing.
          </p>
        </div>
      </div>

      <CTASection type="review" />
    </div>
  </section>
</Layout>

<style>
  .review-definition {
    max-width: 860px;
    padding: 1.35rem;
  }

  .review-definition p {
    margin: 0;
    color: var(--colour-muted);
    font-size: 1.05rem;
  }

  .track-grid,
  .deliverable-grid,
  .useful-grid {
    display: grid;
    gap: 1.25rem;
  }

  .track-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .deliverable-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .useful-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .track-card,
  .deliverable-card,
  .useful-card,
  .anti-hype {
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .track-card {
    display: grid;
    gap: 1rem;
  }

  .track-card h2,
  .deliverable-card h2,
  .anti-hype h2 {
    margin: 0;
    color: var(--colour-dark);
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .track-card p,
  .useful-card p,
  .anti-hype p:not(.eyebrow) {
    margin: 0;
    color: var(--colour-muted);
  }

  .track-card__route {
    padding-top: 1rem;
    border-top: 1px solid var(--colour-line);
    font-weight: 700;
  }

  .deliverable-card {
    display: flex;
    align-items: center;
    min-height: 120px;
  }

  .useful-card p {
    font-weight: 700;
  }

  .anti-hype {
    background:
      radial-gradient(circle at top right, rgba(0, 153, 255, 0.1), transparent 24rem),
      var(--colour-white);
  }

  .anti-hype p:not(.eyebrow) {
    max-width: 860px;
    margin-top: 0.9rem;
  }

  @media (max-width: 980px) {
    .deliverable-grid,
    .useful-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .track-grid,
    .deliverable-grid,
    .useful-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
